# Slack — required for alerts
SLACK_WEBHOOK_URL=your-slack-webhook-url-here
SLACK_SIGNING_SECRET=your-signing-secret-here

# Scanner settings
SCAN_INTERVAL_MINUTES=15
ALERT_THRESHOLD_PCT=5.0
SCAN_CURRENCIES=BTC,ETH
MAX_EXPIRY_DAYS=2

# Persistent SQLite database — REQUIRED for alert deduplication and trade tracking.
# On Railway, create a Volume (e.g. mounted at /data) and set this to a path on
# that volume so the DB survives redeploys and restarts.
DATABASE_URL=/data/scanner.db
# ALERT_RETENTION_DAYS=90

# Server (Railway sets PORT automatically)
PORT=8080

# --- Predict.fun Trading (disabled by default) ---
# Set TRADE_ENABLED=true to activate auto-trading on alerts
TRADE_ENABLED=false

# Predict.fun API/trading credentials (required when TRADE_ENABLED=true)
# Mainnet API keys are requested from Predict.fun Discord support.
# See https://docs.predict.fun/developers/predict-rest-api
PREDICTFUN_API_KEY=your-predictfun-api-key
PREDICTFUN_PRIVATE_KEY=0xYourEoaOrPrivyPrivateKeyHere

# Optional: paste a pre-generated JWT for order actions. If unset, the bot
# signs the Predict.fun auth message with PREDICTFUN_PRIVATE_KEY.
# PREDICTFUN_JWT=your-predictfun-jwt

# Optional: set when trading through the smart wallet created by predict.fun.
# This is the Predict Account deposit address. Leave blank for direct EOA
# trading.
# PREDICTFUN_PREDICT_ACCOUNT=0xYourPredictAccountDepositAddress

# Predict.fun API base URL (default shown; override if needed)
# PREDICTFUN_API_BASE=https://api.predict.fun
# PREDICTFUN_CHAIN_ID=56

# Per-request timeout (seconds) for the Predict.fun REST client. Order
# submission may block while matching/settlement completes, so 15s is often too tight.
# Acts as a backwards-compatible default for PREDICTFUN_READ_TIMEOUT below.
# PREDICTFUN_REQUEST_TIMEOUT=60

# Split connect/read timeouts (seconds). Connect should be short — a slow
# TCP handshake almost always means a flaky connection. Read can be long
# because the matching engine sometimes blocks on on-chain settlement.
# PREDICTFUN_CONNECT_TIMEOUT=10
# PREDICTFUN_READ_TIMEOUT=60

# Retry budget for idempotent verbs (GET/HEAD/OPTIONS/DELETE) on the
# trading client. Connection errors, read timeouts, and 5xx responses are
# retried with exponential backoff (sleep = backoff * 2**attempt).
# PREDICTFUN_MAX_RETRIES=3
# PREDICTFUN_RETRY_BACKOFF=0.8

# Retry knobs for the public read-only endpoints used by fetch_predictfun_prob
# (active slugs, market details, orderbook). Always-idempotent GETs.
# PREDICTFUN_PUBLIC_GET_TIMEOUT=20
# PREDICTFUN_PUBLIC_GET_RETRIES=3
# PREDICTFUN_PUBLIC_GET_BACKOFF=0.8

# Trade sizing
# TRADE_SIZE=10                # target share count per trade (cost = shares × price)
# MIN_ORDER_DOLLARS=5.0        # don't submit orders below this USDT notional
# MIN_ORDER_SIZE=5             # don't submit orders below this share count
# MAX_ORDER_DOLLARS=10.0       # hard cap: never commit more than this in USDT per BUY
# TRADE_MIN_BALANCE_USDT=10

# Fee model (defaults should be fine for most users)
# PREDICTFUN_FEE_RATE=0.02
# PREDICTFUN_MIN_TAKER_FEE=0.01

# Position monitor — how often (seconds) to check resting sell orders
# POSITION_CHECK_INTERVAL_SECONDS=30
